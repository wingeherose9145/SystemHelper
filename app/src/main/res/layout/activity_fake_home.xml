<?xml version="1.0" encoding="utf-8"?>

<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F3F4F6">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="System Helper"
            android:textSize="30sp"
            android:textStyle="bold"
            android:textColor="#111111"
            android:paddingBottom="20dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="18dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:text="Battery Health"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#111111"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/batteryText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Excellent"
                android:textSize="16sp"
                android:textColor="#666666"
                android:paddingTop="8dp" />

            <TextView
                android:id="@+id/tempText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Temperature: 33°C"
                android:textSize="16sp"
                android:textColor="#666666"
                android:paddingTop="4dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="18dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:text="RAM Usage"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#111111"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <ProgressBar
                android:id="@+id/ramBar"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingTop="12dp" />

            <TextView
                android:id="@+id/ramText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5.2GB / 8GB Used"
                android:textSize="15sp"
                android:textColor="#666666"
                android:paddingTop="8dp" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:padding="18dp">

            <TextView
                android:text="Storage Cleaner"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#111111"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

            <TextView
                android:id="@+id/cacheText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Junk Cache: 1.7GB"
                android:textSize="16sp"
                android:textColor="#666666"
                android:paddingTop="8dp" />

            <Button
                android:id="@+id/cleanButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Clean Now"
                android:layout_marginTop="14dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>
